<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/cosmic-coffee-step-3/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/cosmic-coffee-step-3/">

    <owl:Ontology rdf:about="http://example.org/ontology/cosmic-coffee-step-3/">
        <rdfs:label>Cosmic Coffee – Step 3</rdfs:label>
        <rdfs:comment>Full supply-chain model adding Supplier and Shipment to complete the bean-to-cup journey.</rdfs:comment>
    </owl:Ontology>

    <!-- ======== Classes ======== -->

    <owl:Class rdf:about="http://example.org/ontology/cosmic-coffee-step-3/Customer">
        <rdfs:label>Customer</rdfs:label>
        <rdfs:comment>A loyalty-program member who places orders</rdfs:comment>
        <ont:icon>👤</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/cosmic-coffee-step-3/Order">
        <rdfs:label>Order</rdfs:label>
        <rdfs:comment>A purchase transaction containing one or more products</rdfs:comment>
        <ont:icon>🧾</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/cosmic-coffee-step-3/Product">
        <rdfs:label>Product</rdfs:label>
        <rdfs:comment>A menu item or merchandise available for sale</rdfs:comment>
        <ont:icon>☕</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/cosmic-coffee-step-3/Store">
        <rdfs:label>Store</rdfs:label>
        <rdfs:comment>A physical retail location where orders are prepared and served</rdfs:comment>
        <ont:icon>🏪</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/cosmic-coffee-step-3/Supplier">
        <rdfs:label>Supplier</rdfs:label>
        <rdfs:comment>A vendor that provides coffee beans, ingredients, or merchandise</rdfs:comment>
        <ont:icon>🚚</ont:icon>
        <ont:color>#D83B01</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/cosmic-coffee-step-3/Shipment">
        <rdfs:label>Shipment</rdfs:label>
        <rdfs:comment>A delivery of products from a supplier to a store</rdfs:comment>
        <ont:icon>📦</ont:icon>
        <ont:color>#00A9E0</ont:color>
    </owl:Class>

    <!-- ======== Customer Properties ======== -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/customer_customerId">
        <rdfs:label>customerId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Customer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/customer_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Customer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/customer_email">
        <rdfs:label>email</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Customer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/customer_loyaltyTier">
        <rdfs:label>loyaltyTier</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Customer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:enumValues>Bronze,Silver,Gold,Platinum</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/customer_joinDate">
        <rdfs:label>joinDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Customer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/customer_totalSpend">
        <rdfs:label>totalSpend</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Customer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>USD</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- ======== Order Properties ======== -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/order_orderId">
        <rdfs:label>orderId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Order"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/order_timestamp">
        <rdfs:label>timestamp</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Order"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/order_total">
        <rdfs:label>total</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Order"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>USD</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/order_status">
        <rdfs:label>status</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Order"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:enumValues>Pending,Preparing,Ready,Completed,Cancelled</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/order_paymentMethod">
        <rdfs:label>paymentMethod</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Order"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:enumValues>Card,Cash,Mobile,Gift Card</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- ======== Product Properties ======== -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/product_productId">
        <rdfs:label>productId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Product"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/product_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Product"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/product_category">
        <rdfs:label>category</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Product"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:enumValues>Espresso,Brewed,Cold Brew,Tea,Food,Merchandise</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/product_price">
        <rdfs:label>price</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Product"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>USD</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/product_origin">
        <rdfs:label>origin</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Product"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/product_isOrganic">
        <rdfs:label>isOrganic</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Product"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <ont:propertyType>boolean</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- ======== Store Properties ======== -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/store_storeId">
        <rdfs:label>storeId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Store"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/store_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Store"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/store_city">
        <rdfs:label>city</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Store"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/store_state">
        <rdfs:label>state</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Store"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/store_openDate">
        <rdfs:label>openDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Store"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/store_capacity">
        <rdfs:label>capacity</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Store"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- ======== Supplier Properties ======== -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/supplier_supplierId">
        <rdfs:label>supplierId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Supplier"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/supplier_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Supplier"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/supplier_country">
        <rdfs:label>country</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Supplier"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/supplier_certification">
        <rdfs:label>certification</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Supplier"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:enumValues>Fair Trade,Rainforest Alliance,Organic,Direct Trade,None</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/supplier_rating">
        <rdfs:label>rating</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Supplier"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- ======== Shipment Properties ======== -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/shipment_shipmentId">
        <rdfs:label>shipmentId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Shipment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/shipment_dispatchDate">
        <rdfs:label>dispatchDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Shipment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/shipment_arrivalDate">
        <rdfs:label>arrivalDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Shipment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/shipment_status">
        <rdfs:label>status</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Shipment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:enumValues>In Transit,Delivered,Delayed</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/shipment_weight">
        <rdfs:label>weight</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Shipment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>kg</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- ======== Relationships ======== -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/customer_places_order">
        <rdfs:label>places</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Customer"/>
        <rdfs:range rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Order"/>
        <rdfs:comment>A customer places one or more orders</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>customer</ont:fromEntityId>
        <ont:toEntityId>order</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/order_contains_product">
        <rdfs:label>contains</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Order"/>
        <rdfs:range rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Product"/>
        <rdfs:comment>An order contains one or more products</rdfs:comment>
        <ont:cardinality>many-to-many</ont:cardinality>
        <ont:fromEntityId>order</ont:fromEntityId>
        <ont:toEntityId>product</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/order_processed_at_store">
        <rdfs:label>processedAt</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Order"/>
        <rdfs:range rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Store"/>
        <rdfs:comment>An order is processed at a specific store</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>order</ont:fromEntityId>
        <ont:toEntityId>store</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/product_sourced_from_supplier">
        <rdfs:label>sourcedFrom</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Product"/>
        <rdfs:range rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Supplier"/>
        <rdfs:comment>A product is sourced from a supplier</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>product</ont:fromEntityId>
        <ont:toEntityId>supplier</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/shipment_from_supplier">
        <rdfs:label>sentBy</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Shipment"/>
        <rdfs:range rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Supplier"/>
        <rdfs:comment>A shipment is sent by a supplier</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>shipment</ont:fromEntityId>
        <ont:toEntityId>supplier</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/shipment_to_store">
        <rdfs:label>deliveredTo</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Shipment"/>
        <rdfs:range rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Store"/>
        <rdfs:comment>A shipment is delivered to a store</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>shipment</ont:fromEntityId>
        <ont:toEntityId>store</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/cosmic-coffee-step-3/shipment_contains_product">
        <rdfs:label>carries</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Shipment"/>
        <rdfs:range rdf:resource="http://example.org/ontology/cosmic-coffee-step-3/Product"/>
        <rdfs:comment>A shipment carries one or more products</rdfs:comment>
        <ont:cardinality>many-to-many</ont:cardinality>
        <ont:fromEntityId>shipment</ont:fromEntityId>
        <ont:toEntityId>product</ont:toEntityId>
    </owl:ObjectProperty>

</rdf:RDF>
