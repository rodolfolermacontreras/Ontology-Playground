<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/manufacturing-step-1/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/manufacturing-step-1/">

    <!-- Classes -->

    <owl:Class rdf:about="http://example.org/ontology/manufacturing-step-1/Machine">
        <rdfs:label>Machine</rdfs:label>
        <rdfs:comment>A manufacturing machine on the factory floor</rdfs:comment>
        <ont:icon>🏭</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/manufacturing-step-1/Sensor">
        <rdfs:label>Sensor</rdfs:label>
        <rdfs:comment>A sensor device that monitors machine parameters</rdfs:comment>
        <ont:icon>📡</ont:icon>
        <ont:color>#00B7C3</ont:color>
    </owl:Class>

    <!-- Data Properties: Machine -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/manufacturing-step-1/machineId">
        <rdfs:label>machineId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-1/Machine"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/manufacturing-step-1/machineModel">
        <rdfs:label>model</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-1/Machine"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/manufacturing-step-1/machineLocation">
        <rdfs:label>location</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-1/Machine"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/manufacturing-step-1/machineStatus">
        <rdfs:label>status</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-1/Machine"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/manufacturing-step-1/lastMaintenance">
        <rdfs:label>lastMaintenance</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-1/Machine"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- Data Properties: Sensor -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/manufacturing-step-1/sensorId">
        <rdfs:label>sensorId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-1/Sensor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/manufacturing-step-1/sensorType">
        <rdfs:label>type</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-1/Sensor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/manufacturing-step-1/sensorUnit">
        <rdfs:label>unit</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-1/Sensor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/manufacturing-step-1/minThreshold">
        <rdfs:label>minThreshold</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-1/Sensor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/manufacturing-step-1/maxThreshold">
        <rdfs:label>maxThreshold</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-1/Sensor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- Object Properties -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/manufacturing-step-1/machine_has_sensor">
        <rdfs:label>monitored_by</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-1/Machine"/>
        <rdfs:range rdf:resource="http://example.org/ontology/manufacturing-step-1/Sensor"/>
        <rdfs:comment>Sensors on machine</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>Machine</ont:fromEntityId>
        <ont:toEntityId>Sensor</ont:toEntityId>
    </owl:ObjectProperty>

</rdf:RDF>
