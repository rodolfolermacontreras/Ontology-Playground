<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/healthcare-step-3/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/healthcare-step-3/">

  <owl:Ontology rdf:about="">
    <rdfs:label>Healthcare System — Step 3</rdfs:label>
    <rdfs:comment>Adds Prescription entity with treatment and prescribing relationships.</rdfs:comment>
  </owl:Ontology>

  <!-- =============== CLASSES =============== -->

  <owl:Class rdf:about="Patient">
    <rdfs:label>Patient</rdfs:label>
    <rdfs:comment>A patient in the healthcare system</rdfs:comment>
    <ont:icon>🏥</ont:icon>
    <ont:color>#0078D4</ont:color>
  </owl:Class>

  <owl:Class rdf:about="Provider">
    <rdfs:label>Provider</rdfs:label>
    <rdfs:comment>A healthcare provider</rdfs:comment>
    <ont:icon>👨‍⚕️</ont:icon>
    <ont:color>#107C10</ont:color>
  </owl:Class>

  <owl:Class rdf:about="Appointment">
    <rdfs:label>Appointment</rdfs:label>
    <rdfs:comment>A scheduled appointment between a patient and a provider</rdfs:comment>
    <ont:icon>📅</ont:icon>
    <ont:color>#FFB900</ont:color>
  </owl:Class>

  <owl:Class rdf:about="Diagnosis">
    <rdfs:label>Diagnosis</rdfs:label>
    <rdfs:comment>A medical diagnosis assigned to a patient</rdfs:comment>
    <ont:icon>🩺</ont:icon>
    <ont:color>#D13438</ont:color>
  </owl:Class>

  <owl:Class rdf:about="Prescription">
    <rdfs:label>Prescription</rdfs:label>
    <rdfs:comment>A medication prescription for treating a diagnosis</rdfs:comment>
    <ont:icon>💊</ont:icon>
    <ont:color>#8764B8</ont:color>
  </owl:Class>

  <!-- =============== DATA PROPERTIES — Patient =============== -->

  <owl:DatatypeProperty rdf:about="patientId">
    <rdfs:label>patientId</rdfs:label>
    <rdfs:domain rdf:resource="Patient"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
    <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="mrn">
    <rdfs:label>mrn</rdfs:label>
    <rdfs:domain rdf:resource="Patient"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="dateOfBirth">
    <rdfs:label>dateOfBirth</rdfs:label>
    <rdfs:domain rdf:resource="Patient"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    <ont:propertyType>date</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="bloodType">
    <rdfs:label>bloodType</rdfs:label>
    <rdfs:domain rdf:resource="Patient"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="allergies">
    <rdfs:label>allergies</rdfs:label>
    <rdfs:domain rdf:resource="Patient"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <!-- =============== DATA PROPERTIES — Provider =============== -->

  <owl:DatatypeProperty rdf:about="providerId">
    <rdfs:label>providerId</rdfs:label>
    <rdfs:domain rdf:resource="Provider"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
    <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="provider_name">
    <rdfs:label>name</rdfs:label>
    <rdfs:domain rdf:resource="Provider"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="specialty">
    <rdfs:label>specialty</rdfs:label>
    <rdfs:domain rdf:resource="Provider"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="licenseNumber">
    <rdfs:label>licenseNumber</rdfs:label>
    <rdfs:domain rdf:resource="Provider"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="department">
    <rdfs:label>department</rdfs:label>
    <rdfs:domain rdf:resource="Provider"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <!-- =============== DATA PROPERTIES — Appointment =============== -->

  <owl:DatatypeProperty rdf:about="appointmentId">
    <rdfs:label>appointmentId</rdfs:label>
    <rdfs:domain rdf:resource="Appointment"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
    <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="scheduledTime">
    <rdfs:label>scheduledTime</rdfs:label>
    <rdfs:domain rdf:resource="Appointment"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    <ont:propertyType>datetime</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="duration">
    <rdfs:label>duration</rdfs:label>
    <rdfs:domain rdf:resource="Appointment"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <ont:propertyType>integer</ont:propertyType>
    <ont:unit>minutes</ont:unit>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="appointment_type">
    <rdfs:label>type</rdfs:label>
    <rdfs:domain rdf:resource="Appointment"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="status">
    <rdfs:label>status</rdfs:label>
    <rdfs:domain rdf:resource="Appointment"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <!-- =============== DATA PROPERTIES — Diagnosis =============== -->

  <owl:DatatypeProperty rdf:about="diagnosisId">
    <rdfs:label>diagnosisId</rdfs:label>
    <rdfs:domain rdf:resource="Diagnosis"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
    <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="icdCode">
    <rdfs:label>icdCode</rdfs:label>
    <rdfs:domain rdf:resource="Diagnosis"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="diagnosis_description">
    <rdfs:label>description</rdfs:label>
    <rdfs:domain rdf:resource="Diagnosis"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="severity">
    <rdfs:label>severity</rdfs:label>
    <rdfs:domain rdf:resource="Diagnosis"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="diagnosedDate">
    <rdfs:label>diagnosedDate</rdfs:label>
    <rdfs:domain rdf:resource="Diagnosis"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    <ont:propertyType>date</ont:propertyType>
  </owl:DatatypeProperty>

  <!-- =============== DATA PROPERTIES — Prescription =============== -->

  <owl:DatatypeProperty rdf:about="rxNumber">
    <rdfs:label>rxNumber</rdfs:label>
    <rdfs:domain rdf:resource="Prescription"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
    <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="medication">
    <rdfs:label>medication</rdfs:label>
    <rdfs:domain rdf:resource="Prescription"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="dosage">
    <rdfs:label>dosage</rdfs:label>
    <rdfs:domain rdf:resource="Prescription"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="frequency">
    <rdfs:label>frequency</rdfs:label>
    <rdfs:domain rdf:resource="Prescription"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="refillsRemaining">
    <rdfs:label>refillsRemaining</rdfs:label>
    <rdfs:domain rdf:resource="Prescription"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <ont:propertyType>integer</ont:propertyType>
  </owl:DatatypeProperty>

  <!-- =============== OBJECT PROPERTIES =============== -->

  <owl:ObjectProperty rdf:about="patient_has_appt">
    <rdfs:label>has_appointment</rdfs:label>
    <rdfs:domain rdf:resource="Patient"/>
    <rdfs:range rdf:resource="Appointment"/>
    <rdfs:comment>Patient's scheduled visits</rdfs:comment>
    <ont:cardinality>one-to-many</ont:cardinality>
    <ont:fromEntityId>Patient</ont:fromEntityId>
    <ont:toEntityId>Appointment</ont:toEntityId>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="provider_sees">
    <rdfs:label>sees</rdfs:label>
    <rdfs:domain rdf:resource="Provider"/>
    <rdfs:range rdf:resource="Appointment"/>
    <rdfs:comment>Provider's appointments</rdfs:comment>
    <ont:cardinality>one-to-many</ont:cardinality>
    <ont:fromEntityId>Provider</ont:fromEntityId>
    <ont:toEntityId>Appointment</ont:toEntityId>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="patient_diagnosed">
    <rdfs:label>diagnosed_with</rdfs:label>
    <rdfs:domain rdf:resource="Patient"/>
    <rdfs:range rdf:resource="Diagnosis"/>
    <rdfs:comment>Patient diagnoses</rdfs:comment>
    <ont:cardinality>one-to-many</ont:cardinality>
    <ont:fromEntityId>Patient</ont:fromEntityId>
    <ont:toEntityId>Diagnosis</ont:toEntityId>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="provider_diagnoses">
    <rdfs:label>diagnoses</rdfs:label>
    <rdfs:domain rdf:resource="Provider"/>
    <rdfs:range rdf:resource="Diagnosis"/>
    <rdfs:comment>Diagnoses made by provider</rdfs:comment>
    <ont:cardinality>one-to-many</ont:cardinality>
    <ont:fromEntityId>Provider</ont:fromEntityId>
    <ont:toEntityId>Diagnosis</ont:toEntityId>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="diagnosis_treated">
    <rdfs:label>treated_by</rdfs:label>
    <rdfs:domain rdf:resource="Diagnosis"/>
    <rdfs:range rdf:resource="Prescription"/>
    <rdfs:comment>Prescriptions for diagnosis</rdfs:comment>
    <ont:cardinality>one-to-many</ont:cardinality>
    <ont:fromEntityId>Diagnosis</ont:fromEntityId>
    <ont:toEntityId>Prescription</ont:toEntityId>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="provider_prescribes">
    <rdfs:label>prescribes</rdfs:label>
    <rdfs:domain rdf:resource="Provider"/>
    <rdfs:range rdf:resource="Prescription"/>
    <rdfs:comment>Provider prescriptions</rdfs:comment>
    <ont:cardinality>one-to-many</ont:cardinality>
    <ont:fromEntityId>Provider</ont:fromEntityId>
    <ont:toEntityId>Prescription</ont:toEntityId>
  </owl:ObjectProperty>

</rdf:RDF>
