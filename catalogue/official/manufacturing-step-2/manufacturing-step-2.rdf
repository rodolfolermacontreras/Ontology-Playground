<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/manufacturing-step-2/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/manufacturing-step-2/">

    <!-- Classes -->

    <owl:Class rdf:about="http://example.org/ontology/manufacturing-step-2/Machine">
        <rdfs:label>Machine</rdfs:label>
        <rdfs:comment>A manufacturing machine on the factory floor</rdfs:comment>
        <ont:icon>🏭</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/manufacturing-step-2/Sensor">
        <rdfs:label>Sensor</rdfs:label>
        <rdfs:comment>A sensor device that monitors machine parameters</rdfs:comment>
        <ont:icon>📡</ont:icon>
        <ont:color>#00B7C3</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/manufacturing-step-2/Workorder">
        <rdfs:label>Work-Order</rdfs:label>
        <rdfs:comment>A work order for manufacturing a product</rdfs:comment>
        <ont:icon>📋</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/manufacturing-step-2/Part">
        <rdfs:label>Part</rdfs:label>
        <rdfs:comment>A component or spare part used in manufacturing</rdfs:comment>
        <ont:icon>🔩</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <!-- Data Properties: Machine -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/manufacturing-step-2/machineId">
        <rdfs:label>machineId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-2/Machine"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/manufacturing-step-2/machineModel">
        <rdfs:label>model</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-2/Machine"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/manufacturing-step-2/machineLocation">
        <rdfs:label>location</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-2/Machine"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/manufacturing-step-2/machineStatus">
        <rdfs:label>status</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-2/Machine"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/manufacturing-step-2/lastMaintenance">
        <rdfs:label>lastMaintenance</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-2/Machine"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- Data Properties: Sensor -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/manufacturing-step-2/sensorId">
        <rdfs:label>sensorId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-2/Sensor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/manufacturing-step-2/sensorType">
        <rdfs:label>type</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-2/Sensor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/manufacturing-step-2/sensorUnit">
        <rdfs:label>unit</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-2/Sensor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/manufacturing-step-2/minThreshold">
        <rdfs:label>minThreshold</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-2/Sensor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/manufacturing-step-2/maxThreshold">
        <rdfs:label>maxThreshold</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-2/Sensor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- Data Properties: Work-Order -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/manufacturing-step-2/workOrderId">
        <rdfs:label>workOrderId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-2/Workorder"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/manufacturing-step-2/product">
        <rdfs:label>product</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-2/Workorder"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/manufacturing-step-2/quantity">
        <rdfs:label>quantity</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-2/Workorder"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/manufacturing-step-2/priority">
        <rdfs:label>priority</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-2/Workorder"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/manufacturing-step-2/dueDate">
        <rdfs:label>dueDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-2/Workorder"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- Data Properties: Part -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/manufacturing-step-2/partNumber">
        <rdfs:label>partNumber</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-2/Part"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/manufacturing-step-2/partName">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-2/Part"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/manufacturing-step-2/stockLevel">
        <rdfs:label>stockLevel</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-2/Part"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/manufacturing-step-2/reorderPoint">
        <rdfs:label>reorderPoint</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-2/Part"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/manufacturing-step-2/unitCost">
        <rdfs:label>unitCost</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-2/Part"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
        <ont:unit>USD</ont:unit>
    </owl:DatatypeProperty>

    <!-- Object Properties -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/manufacturing-step-2/machine_has_sensor">
        <rdfs:label>monitored_by</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-2/Machine"/>
        <rdfs:range rdf:resource="http://example.org/ontology/manufacturing-step-2/Sensor"/>
        <rdfs:comment>Sensors on machine</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>Machine</ont:fromEntityId>
        <ont:toEntityId>Sensor</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/manufacturing-step-2/machine_runs">
        <rdfs:label>executes</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-2/Machine"/>
        <rdfs:range rdf:resource="http://example.org/ontology/manufacturing-step-2/Workorder"/>
        <rdfs:comment>Work orders on machine</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>Machine</ont:fromEntityId>
        <ont:toEntityId>Workorder</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/manufacturing-step-2/workorder_uses">
        <rdfs:label>uses</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-2/Workorder"/>
        <rdfs:range rdf:resource="http://example.org/ontology/manufacturing-step-2/Part"/>
        <rdfs:comment>Parts consumed</rdfs:comment>
        <ont:cardinality>many-to-many</ont:cardinality>
        <ont:fromEntityId>Workorder</ont:fromEntityId>
        <ont:toEntityId>Part</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/manufacturing-step-2/machine_maintains">
        <rdfs:label>requires</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/manufacturing-step-2/Machine"/>
        <rdfs:range rdf:resource="http://example.org/ontology/manufacturing-step-2/Part"/>
        <rdfs:comment>Spare parts needed</rdfs:comment>
        <ont:cardinality>many-to-many</ont:cardinality>
        <ont:fromEntityId>Machine</ont:fromEntityId>
        <ont:toEntityId>Part</ont:toEntityId>
    </owl:ObjectProperty>

</rdf:RDF>
