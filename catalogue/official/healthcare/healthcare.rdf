<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/healthcare-system/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/healthcare-system/">

    <owl:Ontology rdf:about="http://example.org/ontology/healthcare-system/">
        <rdfs:label>Healthcare System</rdfs:label>
        <rdfs:comment>Patient care management with providers, appointments, and treatments</rdfs:comment>
    </owl:Ontology>

    <!-- ===================== -->
    <!-- Entity Types (Classes) -->
    <!-- ===================== -->

    <owl:Class rdf:about="http://example.org/ontology/healthcare-system/Patient">
        <rdfs:label>Patient</rdfs:label>
        <rdfs:comment>Individual receiving medical care</rdfs:comment>
        <ont:icon>🏥</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/healthcare-system/Provider">
        <rdfs:label>Provider</rdfs:label>
        <rdfs:comment>Healthcare professional</rdfs:comment>
        <ont:icon>👨‍⚕️</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/healthcare-system/Appointment">
        <rdfs:label>Appointment</rdfs:label>
        <rdfs:comment>Scheduled patient visit</rdfs:comment>
        <ont:icon>📅</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/healthcare-system/Diagnosis">
        <rdfs:label>Diagnosis</rdfs:label>
        <rdfs:comment>Medical condition identified</rdfs:comment>
        <ont:icon>🩺</ont:icon>
        <ont:color>#D13438</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/healthcare-system/Prescription">
        <rdfs:label>Prescription</rdfs:label>
        <rdfs:comment>Medication order</rdfs:comment>
        <ont:icon>💊</ont:icon>
        <ont:color>#8764B8</ont:color>
    </owl:Class>

    <!-- ================ -->
    <!-- Data Properties -->
    <!-- ================ -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/patient_patientId">
        <rdfs:label>patientId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Patient"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/patient_mrn">
        <rdfs:label>mrn</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Patient"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/patient_dateOfBirth">
        <rdfs:label>dateOfBirth</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Patient"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/patient_bloodType">
        <rdfs:label>bloodType</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Patient"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/patient_allergies">
        <rdfs:label>allergies</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Patient"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/provider_providerId">
        <rdfs:label>providerId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Provider"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/provider_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Provider"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/provider_specialty">
        <rdfs:label>specialty</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Provider"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/provider_licenseNumber">
        <rdfs:label>licenseNumber</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Provider"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/provider_department">
        <rdfs:label>department</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Provider"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/appointment_appointmentId">
        <rdfs:label>appointmentId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Appointment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/appointment_scheduledTime">
        <rdfs:label>scheduledTime</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Appointment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/appointment_duration">
        <rdfs:label>duration</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Appointment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ont:unit>minutes</ont:unit>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/appointment_type">
        <rdfs:label>type</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Appointment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/appointment_status">
        <rdfs:label>status</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Appointment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/diagnosis_diagnosisId">
        <rdfs:label>diagnosisId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Diagnosis"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/diagnosis_icdCode">
        <rdfs:label>icdCode</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Diagnosis"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/diagnosis_description">
        <rdfs:label>description</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Diagnosis"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/diagnosis_severity">
        <rdfs:label>severity</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Diagnosis"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/diagnosis_diagnosedDate">
        <rdfs:label>diagnosedDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Diagnosis"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/prescription_rxNumber">
        <rdfs:label>rxNumber</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Prescription"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/prescription_medication">
        <rdfs:label>medication</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Prescription"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/prescription_dosage">
        <rdfs:label>dosage</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Prescription"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/prescription_frequency">
        <rdfs:label>frequency</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Prescription"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/prescription_refillsRemaining">
        <rdfs:label>refillsRemaining</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Prescription"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- ================== -->
    <!-- Object Properties -->
    <!-- ================== -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/healthcare-system/patient_has_appt">
        <rdfs:label>has_appointment</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Patient"/>
        <rdfs:range rdf:resource="http://example.org/ontology/healthcare-system/Appointment"/>
        <rdfs:comment>Patient&apos;s scheduled visits</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>patient</ont:fromEntityId>
        <ont:toEntityId>appointment</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/healthcare-system/provider_sees">
        <rdfs:label>sees</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Provider"/>
        <rdfs:range rdf:resource="http://example.org/ontology/healthcare-system/Appointment"/>
        <rdfs:comment>Provider&apos;s appointments</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>provider</ont:fromEntityId>
        <ont:toEntityId>appointment</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/healthcare-system/patient_diagnosed">
        <rdfs:label>diagnosed_with</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Patient"/>
        <rdfs:range rdf:resource="http://example.org/ontology/healthcare-system/Diagnosis"/>
        <rdfs:comment>Patient diagnoses</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>patient</ont:fromEntityId>
        <ont:toEntityId>diagnosis</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/healthcare-system/provider_diagnoses">
        <rdfs:label>diagnoses</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Provider"/>
        <rdfs:range rdf:resource="http://example.org/ontology/healthcare-system/Diagnosis"/>
        <rdfs:comment>Diagnoses made by provider</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>provider</ont:fromEntityId>
        <ont:toEntityId>diagnosis</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/healthcare-system/diagnosis_treated">
        <rdfs:label>treated_by</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Diagnosis"/>
        <rdfs:range rdf:resource="http://example.org/ontology/healthcare-system/Prescription"/>
        <rdfs:comment>Prescriptions for diagnosis</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>diagnosis</ont:fromEntityId>
        <ont:toEntityId>prescription</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/healthcare-system/provider_prescribes">
        <rdfs:label>prescribes</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Provider"/>
        <rdfs:range rdf:resource="http://example.org/ontology/healthcare-system/Prescription"/>
        <rdfs:comment>Provider prescriptions</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>provider</ont:fromEntityId>
        <ont:toEntityId>prescription</ont:toEntityId>
    </owl:ObjectProperty>

</rdf:RDF>
