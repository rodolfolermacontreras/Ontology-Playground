<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/ecommerce-step-2/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/ecommerce-step-2/">

  <owl:Ontology rdf:about="">
    <rdfs:label>E-Commerce Platform – Step 2</rdfs:label>
    <rdfs:comment>Adds Shopping Cart to the foundation, enabling cart-based workflows before checkout.</rdfs:comment>
  </owl:Ontology>

  <!-- ============================================================ -->
  <!-- Classes                                                       -->
  <!-- ============================================================ -->

  <owl:Class rdf:about="Buyer">
    <rdfs:label>Buyer</rdfs:label>
    <rdfs:comment>A customer who purchases products on the platform.</rdfs:comment>
    <ont:icon>🛒</ont:icon>
    <ont:color>#0078D4</ont:color>
  </owl:Class>

  <owl:Class rdf:about="Product">
    <rdfs:label>Product</rdfs:label>
    <rdfs:comment>An item available for purchase on the platform.</rdfs:comment>
    <ont:icon>📦</ont:icon>
    <ont:color>#107C10</ont:color>
  </owl:Class>

  <owl:Class rdf:about="Order">
    <rdfs:label>Order</rdfs:label>
    <rdfs:comment>A purchase order placed by a buyer.</rdfs:comment>
    <ont:icon>📋</ont:icon>
    <ont:color>#8764B8</ont:color>
  </owl:Class>

  <owl:Class rdf:about="ShoppingCart">
    <rdfs:label>Shopping Cart</rdfs:label>
    <rdfs:comment>A temporary collection of products a buyer intends to purchase.</rdfs:comment>
    <ont:icon>🛍️</ont:icon>
    <ont:color>#FFB900</ont:color>
  </owl:Class>

  <!-- ============================================================ -->
  <!-- Buyer Data Properties                                         -->
  <!-- ============================================================ -->

  <owl:DatatypeProperty rdf:about="buyerId">
    <rdfs:label>buyerId</rdfs:label>
    <rdfs:domain rdf:resource="Buyer"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
    <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="email">
    <rdfs:label>email</rdfs:label>
    <rdfs:domain rdf:resource="Buyer"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="memberSince">
    <rdfs:label>memberSince</rdfs:label>
    <rdfs:domain rdf:resource="Buyer"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    <ont:propertyType>date</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="loyaltyTier">
    <rdfs:label>loyaltyTier</rdfs:label>
    <rdfs:domain rdf:resource="Buyer"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="totalSpent">
    <rdfs:label>totalSpent</rdfs:label>
    <rdfs:domain rdf:resource="Buyer"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <ont:propertyType>decimal</ont:propertyType>
    <ont:unit>USD</ont:unit>
  </owl:DatatypeProperty>

  <!-- ============================================================ -->
  <!-- Product Data Properties                                       -->
  <!-- ============================================================ -->

  <owl:DatatypeProperty rdf:about="sku">
    <rdfs:label>sku</rdfs:label>
    <rdfs:domain rdf:resource="Product"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
    <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="productName">
    <rdfs:label>name</rdfs:label>
    <rdfs:domain rdf:resource="Product"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="category">
    <rdfs:label>category</rdfs:label>
    <rdfs:domain rdf:resource="Product"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="price">
    <rdfs:label>price</rdfs:label>
    <rdfs:domain rdf:resource="Product"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <ont:propertyType>decimal</ont:propertyType>
    <ont:unit>USD</ont:unit>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="stockQty">
    <rdfs:label>stockQty</rdfs:label>
    <rdfs:domain rdf:resource="Product"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <ont:propertyType>integer</ont:propertyType>
  </owl:DatatypeProperty>

  <!-- ============================================================ -->
  <!-- Order Data Properties                                         -->
  <!-- ============================================================ -->

  <owl:DatatypeProperty rdf:about="orderId">
    <rdfs:label>orderId</rdfs:label>
    <rdfs:domain rdf:resource="Order"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
    <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="orderDate">
    <rdfs:label>orderDate</rdfs:label>
    <rdfs:domain rdf:resource="Order"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    <ont:propertyType>datetime</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="status">
    <rdfs:label>status</rdfs:label>
    <rdfs:domain rdf:resource="Order"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="total">
    <rdfs:label>total</rdfs:label>
    <rdfs:domain rdf:resource="Order"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <ont:propertyType>decimal</ont:propertyType>
    <ont:unit>USD</ont:unit>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="shippingMethod">
    <rdfs:label>shippingMethod</rdfs:label>
    <rdfs:domain rdf:resource="Order"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <!-- ============================================================ -->
  <!-- Shopping Cart Data Properties                                 -->
  <!-- ============================================================ -->

  <owl:DatatypeProperty rdf:about="cartId">
    <rdfs:label>cartId</rdfs:label>
    <rdfs:domain rdf:resource="ShoppingCart"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
    <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="createdAt">
    <rdfs:label>createdAt</rdfs:label>
    <rdfs:domain rdf:resource="ShoppingCart"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    <ont:propertyType>datetime</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="itemCount">
    <rdfs:label>itemCount</rdfs:label>
    <rdfs:domain rdf:resource="ShoppingCart"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <ont:propertyType>integer</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="subtotal">
    <rdfs:label>subtotal</rdfs:label>
    <rdfs:domain rdf:resource="ShoppingCart"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <ont:propertyType>decimal</ont:propertyType>
    <ont:unit>USD</ont:unit>
  </owl:DatatypeProperty>

  <!-- ============================================================ -->
  <!-- Object Properties (Relationships)                             -->
  <!-- ============================================================ -->

  <owl:ObjectProperty rdf:about="places">
    <rdfs:label>places</rdfs:label>
    <rdfs:domain rdf:resource="Buyer"/>
    <rdfs:range rdf:resource="Order"/>
    <rdfs:comment>A buyer places an order.</rdfs:comment>
    <ont:cardinality>one-to-many</ont:cardinality>
    <ont:fromEntityId>Buyer</ont:fromEntityId>
    <ont:toEntityId>Order</ont:toEntityId>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="includes">
    <rdfs:label>includes</rdfs:label>
    <rdfs:domain rdf:resource="Order"/>
    <rdfs:range rdf:resource="Product"/>
    <rdfs:comment>An order includes one or more products.</rdfs:comment>
    <ont:cardinality>many-to-many</ont:cardinality>
    <ont:fromEntityId>Order</ont:fromEntityId>
    <ont:toEntityId>Product</ont:toEntityId>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="has_cart">
    <rdfs:label>has_cart</rdfs:label>
    <rdfs:domain rdf:resource="Buyer"/>
    <rdfs:range rdf:resource="ShoppingCart"/>
    <rdfs:comment>A buyer has a shopping cart.</rdfs:comment>
    <ont:cardinality>one-to-one</ont:cardinality>
    <ont:fromEntityId>Buyer</ont:fromEntityId>
    <ont:toEntityId>ShoppingCart</ont:toEntityId>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="contains">
    <rdfs:label>contains</rdfs:label>
    <rdfs:domain rdf:resource="ShoppingCart"/>
    <rdfs:range rdf:resource="Product"/>
    <rdfs:comment>A shopping cart contains products.</rdfs:comment>
    <ont:cardinality>many-to-many</ont:cardinality>
    <ont:fromEntityId>ShoppingCart</ont:fromEntityId>
    <ont:toEntityId>Product</ont:toEntityId>
  </owl:ObjectProperty>

</rdf:RDF>
