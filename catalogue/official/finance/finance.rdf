<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/banking-finance/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/banking-finance/">

    <owl:Ontology rdf:about="http://example.org/ontology/banking-finance/">
        <rdfs:label>Banking &amp; Finance</rdfs:label>
        <rdfs:comment>Financial services with accounts, transactions, and investments</rdfs:comment>
    </owl:Ontology>

    <!-- ===================== -->
    <!-- Entity Types (Classes) -->
    <!-- ===================== -->

    <owl:Class rdf:about="http://example.org/ontology/banking-finance/Customer">
        <rdfs:label>Customer</rdfs:label>
        <rdfs:comment>Bank account holder</rdfs:comment>
        <ont:icon>👤</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/banking-finance/Account">
        <rdfs:label>Account</rdfs:label>
        <rdfs:comment>Financial account</rdfs:comment>
        <ont:icon>🏦</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/banking-finance/Transaction">
        <rdfs:label>Transaction</rdfs:label>
        <rdfs:comment>Financial transaction</rdfs:comment>
        <ont:icon>💳</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/banking-finance/Loan">
        <rdfs:label>Loan</rdfs:label>
        <rdfs:comment>Credit product</rdfs:comment>
        <ont:icon>📄</ont:icon>
        <ont:color>#D13438</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/banking-finance/Investment">
        <rdfs:label>Investment</rdfs:label>
        <rdfs:comment>Investment holding</rdfs:comment>
        <ont:icon>📈</ont:icon>
        <ont:color>#8764B8</ont:color>
    </owl:Class>

    <!-- ================ -->
    <!-- Data Properties -->
    <!-- ================ -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/banking-finance/customer_customerId">
        <rdfs:label>customerId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/banking-finance/Customer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/banking-finance/customer_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/banking-finance/Customer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/banking-finance/customer_ssn">
        <rdfs:label>ssn</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/banking-finance/Customer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/banking-finance/customer_creditScore">
        <rdfs:label>creditScore</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/banking-finance/Customer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/banking-finance/customer_riskProfile">
        <rdfs:label>riskProfile</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/banking-finance/Customer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/banking-finance/account_accountNumber">
        <rdfs:label>accountNumber</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/banking-finance/Account"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/banking-finance/account_type">
        <rdfs:label>type</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/banking-finance/Account"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/banking-finance/account_balance">
        <rdfs:label>balance</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/banking-finance/Account"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>USD</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/banking-finance/account_interestRate">
        <rdfs:label>interestRate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/banking-finance/Account"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>%</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/banking-finance/account_openDate">
        <rdfs:label>openDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/banking-finance/Account"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/banking-finance/transaction_transactionId">
        <rdfs:label>transactionId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/banking-finance/Transaction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/banking-finance/transaction_amount">
        <rdfs:label>amount</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/banking-finance/Transaction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>USD</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/banking-finance/transaction_type">
        <rdfs:label>type</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/banking-finance/Transaction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/banking-finance/transaction_timestamp">
        <rdfs:label>timestamp</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/banking-finance/Transaction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/banking-finance/transaction_merchant">
        <rdfs:label>merchant</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/banking-finance/Transaction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/banking-finance/loan_loanId">
        <rdfs:label>loanId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/banking-finance/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/banking-finance/loan_principal">
        <rdfs:label>principal</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/banking-finance/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>USD</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/banking-finance/loan_apr">
        <rdfs:label>apr</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/banking-finance/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>%</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/banking-finance/loan_term">
        <rdfs:label>term</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/banking-finance/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ont:unit>months</ont:unit>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/banking-finance/loan_status">
        <rdfs:label>status</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/banking-finance/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/banking-finance/investment_holdingId">
        <rdfs:label>holdingId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/banking-finance/Investment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/banking-finance/investment_symbol">
        <rdfs:label>symbol</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/banking-finance/Investment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/banking-finance/investment_shares">
        <rdfs:label>shares</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/banking-finance/Investment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/banking-finance/investment_purchasePrice">
        <rdfs:label>purchasePrice</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/banking-finance/Investment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>USD</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/banking-finance/investment_currentValue">
        <rdfs:label>currentValue</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/banking-finance/Investment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>USD</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- ================== -->
    <!-- Object Properties -->
    <!-- ================== -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/banking-finance/customer_owns_acct">
        <rdfs:label>owns</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/banking-finance/Customer"/>
        <rdfs:range rdf:resource="http://example.org/ontology/banking-finance/Account"/>
        <rdfs:comment>Customer&apos;s accounts</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>customer</ont:fromEntityId>
        <ont:toEntityId>account</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/banking-finance/account_has_txn">
        <rdfs:label>has_transaction</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/banking-finance/Account"/>
        <rdfs:range rdf:resource="http://example.org/ontology/banking-finance/Transaction"/>
        <rdfs:comment>Account transactions</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>account</ont:fromEntityId>
        <ont:toEntityId>transaction</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/banking-finance/customer_has_loan">
        <rdfs:label>has_loan</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/banking-finance/Customer"/>
        <rdfs:range rdf:resource="http://example.org/ontology/banking-finance/Loan"/>
        <rdfs:comment>Customer loans</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>customer</ont:fromEntityId>
        <ont:toEntityId>loan</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/banking-finance/account_funds_loan">
        <rdfs:label>funds</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/banking-finance/Account"/>
        <rdfs:range rdf:resource="http://example.org/ontology/banking-finance/Loan"/>
        <rdfs:comment>Payment source</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>account</ont:fromEntityId>
        <ont:toEntityId>loan</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/banking-finance/customer_holds">
        <rdfs:label>holds</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/banking-finance/Customer"/>
        <rdfs:range rdf:resource="http://example.org/ontology/banking-finance/Investment"/>
        <rdfs:comment>Investment portfolio</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>customer</ont:fromEntityId>
        <ont:toEntityId>investment</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/banking-finance/account_linked">
        <rdfs:label>linked_to</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/banking-finance/Account"/>
        <rdfs:range rdf:resource="http://example.org/ontology/banking-finance/Investment"/>
        <rdfs:comment>Brokerage account link</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>account</ont:fromEntityId>
        <ont:toEntityId>investment</ont:toEntityId>
    </owl:ObjectProperty>

</rdf:RDF>
