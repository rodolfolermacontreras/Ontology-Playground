<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/smart-manufacturing/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/smart-manufacturing/">

    <owl:Ontology rdf:about="http://example.org/ontology/smart-manufacturing/">
        <rdfs:label>Smart Manufacturing</rdfs:label>
        <rdfs:comment>Production line with assets, sensors, and quality control</rdfs:comment>
    </owl:Ontology>

    <!-- ===================== -->
    <!-- Entity Types (Classes) -->
    <!-- ===================== -->

    <owl:Class rdf:about="http://example.org/ontology/smart-manufacturing/Machine">
        <rdfs:label>Machine</rdfs:label>
        <rdfs:comment>Production equipment</rdfs:comment>
        <ont:icon>🏭</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/smart-manufacturing/Sensor">
        <rdfs:label>Sensor</rdfs:label>
        <rdfs:comment>IoT monitoring device</rdfs:comment>
        <ont:icon>📡</ont:icon>
        <ont:color>#00B7C3</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/smart-manufacturing/Workorder">
        <rdfs:label>Work Order</rdfs:label>
        <rdfs:comment>Production job</rdfs:comment>
        <ont:icon>📋</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/smart-manufacturing/Part">
        <rdfs:label>Part</rdfs:label>
        <rdfs:comment>Component or material</rdfs:comment>
        <ont:icon>🔩</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/smart-manufacturing/Qualitycheck">
        <rdfs:label>Quality Check</rdfs:label>
        <rdfs:comment>Inspection result</rdfs:comment>
        <ont:icon>✅</ont:icon>
        <ont:color>#8764B8</ont:color>
    </owl:Class>

    <!-- ================ -->
    <!-- Data Properties -->
    <!-- ================ -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/smart-manufacturing/machine_machineId">
        <rdfs:label>machineId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/smart-manufacturing/Machine"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/smart-manufacturing/machine_model">
        <rdfs:label>model</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/smart-manufacturing/Machine"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/smart-manufacturing/machine_location">
        <rdfs:label>location</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/smart-manufacturing/Machine"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/smart-manufacturing/machine_status">
        <rdfs:label>status</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/smart-manufacturing/Machine"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/smart-manufacturing/machine_lastMaintenance">
        <rdfs:label>lastMaintenance</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/smart-manufacturing/Machine"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/smart-manufacturing/sensor_sensorId">
        <rdfs:label>sensorId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/smart-manufacturing/Sensor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/smart-manufacturing/sensor_type">
        <rdfs:label>type</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/smart-manufacturing/Sensor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/smart-manufacturing/sensor_unit">
        <rdfs:label>unit</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/smart-manufacturing/Sensor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/smart-manufacturing/sensor_minThreshold">
        <rdfs:label>minThreshold</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/smart-manufacturing/Sensor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/smart-manufacturing/sensor_maxThreshold">
        <rdfs:label>maxThreshold</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/smart-manufacturing/Sensor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/smart-manufacturing/workorder_workOrderId">
        <rdfs:label>workOrderId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/smart-manufacturing/Workorder"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/smart-manufacturing/workorder_product">
        <rdfs:label>product</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/smart-manufacturing/Workorder"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/smart-manufacturing/workorder_quantity">
        <rdfs:label>quantity</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/smart-manufacturing/Workorder"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/smart-manufacturing/workorder_priority">
        <rdfs:label>priority</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/smart-manufacturing/Workorder"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/smart-manufacturing/workorder_dueDate">
        <rdfs:label>dueDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/smart-manufacturing/Workorder"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/smart-manufacturing/part_partNumber">
        <rdfs:label>partNumber</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/smart-manufacturing/Part"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/smart-manufacturing/part_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/smart-manufacturing/Part"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/smart-manufacturing/part_stockLevel">
        <rdfs:label>stockLevel</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/smart-manufacturing/Part"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/smart-manufacturing/part_reorderPoint">
        <rdfs:label>reorderPoint</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/smart-manufacturing/Part"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/smart-manufacturing/part_unitCost">
        <rdfs:label>unitCost</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/smart-manufacturing/Part"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>USD</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/smart-manufacturing/qualitycheck_checkId">
        <rdfs:label>checkId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/smart-manufacturing/Qualitycheck"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/smart-manufacturing/qualitycheck_timestamp">
        <rdfs:label>timestamp</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/smart-manufacturing/Qualitycheck"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/smart-manufacturing/qualitycheck_passed">
        <rdfs:label>passed</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/smart-manufacturing/Qualitycheck"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <ont:propertyType>boolean</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/smart-manufacturing/qualitycheck_defectType">
        <rdfs:label>defectType</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/smart-manufacturing/Qualitycheck"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/smart-manufacturing/qualitycheck_inspector">
        <rdfs:label>inspector</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/smart-manufacturing/Qualitycheck"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- ================== -->
    <!-- Object Properties -->
    <!-- ================== -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/smart-manufacturing/machine_has_sensor">
        <rdfs:label>monitored_by</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/smart-manufacturing/Machine"/>
        <rdfs:range rdf:resource="http://example.org/ontology/smart-manufacturing/Sensor"/>
        <rdfs:comment>Sensors on machine</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>machine</ont:fromEntityId>
        <ont:toEntityId>sensor</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/smart-manufacturing/machine_runs">
        <rdfs:label>executes</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/smart-manufacturing/Machine"/>
        <rdfs:range rdf:resource="http://example.org/ontology/smart-manufacturing/Workorder"/>
        <rdfs:comment>Work orders on machine</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>machine</ont:fromEntityId>
        <ont:toEntityId>workorder</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/smart-manufacturing/workorder_uses">
        <rdfs:label>uses</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/smart-manufacturing/Workorder"/>
        <rdfs:range rdf:resource="http://example.org/ontology/smart-manufacturing/Part"/>
        <rdfs:comment>Parts consumed</rdfs:comment>
        <ont:cardinality>many-to-many</ont:cardinality>
        <ont:fromEntityId>workorder</ont:fromEntityId>
        <ont:toEntityId>part</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/smart-manufacturing/workorder_checked">
        <rdfs:label>inspected_by</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/smart-manufacturing/Workorder"/>
        <rdfs:range rdf:resource="http://example.org/ontology/smart-manufacturing/Qualitycheck"/>
        <rdfs:comment>Quality inspections</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>workorder</ont:fromEntityId>
        <ont:toEntityId>qualitycheck</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/smart-manufacturing/machine_maintains">
        <rdfs:label>requires</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/smart-manufacturing/Machine"/>
        <rdfs:range rdf:resource="http://example.org/ontology/smart-manufacturing/Part"/>
        <rdfs:comment>Spare parts needed</rdfs:comment>
        <ont:cardinality>many-to-many</ont:cardinality>
        <ont:fromEntityId>machine</ont:fromEntityId>
        <ont:toEntityId>part</ont:toEntityId>
    </owl:ObjectProperty>

</rdf:RDF>
