<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/university-system/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/university-system/">

    <owl:Ontology rdf:about="http://example.org/ontology/university-system/">
        <rdfs:label>University System</rdfs:label>
        <rdfs:comment>Academic institution with students, courses, and faculty</rdfs:comment>
    </owl:Ontology>

    <!-- ===================== -->
    <!-- Entity Types (Classes) -->
    <!-- ===================== -->

    <owl:Class rdf:about="http://example.org/ontology/university-system/Student">
        <rdfs:label>Student</rdfs:label>
        <rdfs:comment>Enrolled learner</rdfs:comment>
        <ont:icon>🎓</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/university-system/Professor">
        <rdfs:label>Professor</rdfs:label>
        <rdfs:comment>Faculty member</rdfs:comment>
        <ont:icon>👨‍🏫</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/university-system/Course">
        <rdfs:label>Course</rdfs:label>
        <rdfs:comment>Academic class</rdfs:comment>
        <ont:icon>📚</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/university-system/Department">
        <rdfs:label>Department</rdfs:label>
        <rdfs:comment>Academic unit</rdfs:comment>
        <ont:icon>🏛️</ont:icon>
        <ont:color>#8764B8</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/university-system/Enrollment">
        <rdfs:label>Enrollment</rdfs:label>
        <rdfs:comment>Course registration</rdfs:comment>
        <ont:icon>📝</ont:icon>
        <ont:color>#00B7C3</ont:color>
    </owl:Class>

    <!-- ================ -->
    <!-- Data Properties -->
    <!-- ================ -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/university-system/student_studentId">
        <rdfs:label>studentId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/university-system/Student"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/university-system/student_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/university-system/Student"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/university-system/student_major">
        <rdfs:label>major</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/university-system/Student"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/university-system/student_gpa">
        <rdfs:label>gpa</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/university-system/Student"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/university-system/student_enrollmentYear">
        <rdfs:label>enrollmentYear</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/university-system/Student"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/university-system/professor_facultyId">
        <rdfs:label>facultyId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/university-system/Professor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/university-system/professor_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/university-system/Professor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/university-system/professor_department">
        <rdfs:label>department</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/university-system/Professor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/university-system/professor_tenure">
        <rdfs:label>tenure</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/university-system/Professor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <ont:propertyType>boolean</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/university-system/professor_researchArea">
        <rdfs:label>researchArea</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/university-system/Professor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/university-system/course_courseCode">
        <rdfs:label>courseCode</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/university-system/Course"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/university-system/course_title">
        <rdfs:label>title</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/university-system/Course"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/university-system/course_credits">
        <rdfs:label>credits</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/university-system/Course"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/university-system/course_level">
        <rdfs:label>level</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/university-system/Course"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/university-system/course_maxEnrollment">
        <rdfs:label>maxEnrollment</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/university-system/Course"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/university-system/department_deptCode">
        <rdfs:label>deptCode</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/university-system/Department"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/university-system/department_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/university-system/Department"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/university-system/department_building">
        <rdfs:label>building</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/university-system/Department"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/university-system/department_budget">
        <rdfs:label>budget</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/university-system/Department"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>USD</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/university-system/enrollment_enrollmentId">
        <rdfs:label>enrollmentId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/university-system/Enrollment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/university-system/enrollment_semester">
        <rdfs:label>semester</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/university-system/Enrollment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/university-system/enrollment_grade">
        <rdfs:label>grade</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/university-system/Enrollment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/university-system/enrollment_status">
        <rdfs:label>status</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/university-system/Enrollment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- ================== -->
    <!-- Object Properties -->
    <!-- ================== -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/university-system/student_enrolls">
        <rdfs:label>enrolled_in</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/university-system/Student"/>
        <rdfs:range rdf:resource="http://example.org/ontology/university-system/Enrollment"/>
        <rdfs:comment>Student registrations</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>student</ont:fromEntityId>
        <ont:toEntityId>enrollment</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/university-system/enrollment_for">
        <rdfs:label>for_course</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/university-system/Enrollment"/>
        <rdfs:range rdf:resource="http://example.org/ontology/university-system/Course"/>
        <rdfs:comment>Course enrollment</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>enrollment</ont:fromEntityId>
        <ont:toEntityId>course</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/university-system/prof_teaches">
        <rdfs:label>teaches</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/university-system/Professor"/>
        <rdfs:range rdf:resource="http://example.org/ontology/university-system/Course"/>
        <rdfs:comment>Courses taught</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>professor</ont:fromEntityId>
        <ont:toEntityId>course</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/university-system/prof_belongs">
        <rdfs:label>belongs_to</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/university-system/Professor"/>
        <rdfs:range rdf:resource="http://example.org/ontology/university-system/Department"/>
        <rdfs:comment>Faculty department</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>professor</ont:fromEntityId>
        <ont:toEntityId>department</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/university-system/course_offered">
        <rdfs:label>offered_by</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/university-system/Course"/>
        <rdfs:range rdf:resource="http://example.org/ontology/university-system/Department"/>
        <rdfs:comment>Course department</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>course</ont:fromEntityId>
        <ont:toEntityId>department</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/university-system/student_advised">
        <rdfs:label>advised_by</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/university-system/Student"/>
        <rdfs:range rdf:resource="http://example.org/ontology/university-system/Professor"/>
        <rdfs:comment>Academic advisor</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>student</ont:fromEntityId>
        <ont:toEntityId>professor</ont:toEntityId>
    </owl:ObjectProperty>

</rdf:RDF>
