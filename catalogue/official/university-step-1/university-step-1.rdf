<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/university-step-1/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/university-step-1/">

    <!-- Ontology Declaration -->
    <owl:Ontology rdf:about="">
        <rdfs:label>University System – Step 1</rdfs:label>
        <rdfs:comment>Core student enrollment model: Student, Course, and Enrollment entities.</rdfs:comment>
    </owl:Ontology>

    <!-- ======================== -->
    <!-- Classes                  -->
    <!-- ======================== -->

    <owl:Class rdf:about="#Student">
        <rdfs:label>Student</rdfs:label>
        <rdfs:comment>A student enrolled at the university</rdfs:comment>
        <ont:icon>🎓</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#Course">
        <rdfs:label>Course</rdfs:label>
        <rdfs:comment>An academic course offered by the university</rdfs:comment>
        <ont:icon>📚</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#Enrollment">
        <rdfs:label>Enrollment</rdfs:label>
        <rdfs:comment>A student's registration in a specific course</rdfs:comment>
        <ont:icon>📝</ont:icon>
        <ont:color>#00B7C3</ont:color>
    </owl:Class>

    <!-- ======================== -->
    <!-- Data Properties          -->
    <!-- ======================== -->

    <!-- Student properties -->
    <owl:DatatypeProperty rdf:about="#studentId">
        <rdfs:label>studentId</rdfs:label>
        <rdfs:domain rdf:resource="#Student"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
        <ont:isIdentifier>true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#student_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="#Student"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#major">
        <rdfs:label>major</rdfs:label>
        <rdfs:domain rdf:resource="#Student"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#gpa">
        <rdfs:label>gpa</rdfs:label>
        <rdfs:domain rdf:resource="#Student"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#enrollmentYear">
        <rdfs:label>enrollmentYear</rdfs:label>
        <rdfs:domain rdf:resource="#Student"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- Course properties -->
    <owl:DatatypeProperty rdf:about="#courseCode">
        <rdfs:label>courseCode</rdfs:label>
        <rdfs:domain rdf:resource="#Course"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
        <ont:isIdentifier>true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#title">
        <rdfs:label>title</rdfs:label>
        <rdfs:domain rdf:resource="#Course"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#credits">
        <rdfs:label>credits</rdfs:label>
        <rdfs:domain rdf:resource="#Course"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#level">
        <rdfs:label>level</rdfs:label>
        <rdfs:domain rdf:resource="#Course"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#maxEnrollment">
        <rdfs:label>maxEnrollment</rdfs:label>
        <rdfs:domain rdf:resource="#Course"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- Enrollment properties -->
    <owl:DatatypeProperty rdf:about="#enrollmentId">
        <rdfs:label>enrollmentId</rdfs:label>
        <rdfs:domain rdf:resource="#Enrollment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
        <ont:isIdentifier>true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#semester">
        <rdfs:label>semester</rdfs:label>
        <rdfs:domain rdf:resource="#Enrollment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#grade">
        <rdfs:label>grade</rdfs:label>
        <rdfs:domain rdf:resource="#Enrollment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#status">
        <rdfs:label>status</rdfs:label>
        <rdfs:domain rdf:resource="#Enrollment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- ======================== -->
    <!-- Object Properties        -->
    <!-- ======================== -->

    <owl:ObjectProperty rdf:about="#student_enrolls">
        <rdfs:label>enrolled_in</rdfs:label>
        <rdfs:domain rdf:resource="#Student"/>
        <rdfs:range rdf:resource="#Enrollment"/>
        <rdfs:comment>Student registrations</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>Student</ont:fromEntityId>
        <ont:toEntityId>Enrollment</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#enrollment_for">
        <rdfs:label>for_course</rdfs:label>
        <rdfs:domain rdf:resource="#Enrollment"/>
        <rdfs:range rdf:resource="#Course"/>
        <rdfs:comment>Course enrollment</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>Enrollment</ont:fromEntityId>
        <ont:toEntityId>Course</ont:toEntityId>
    </owl:ObjectProperty>

</rdf:RDF>
