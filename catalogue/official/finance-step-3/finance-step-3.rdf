<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/finance-step-3/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/finance-step-3/">

  <owl:Ontology rdf:about="">
    <rdfs:label>Banking &amp; Finance – Step 3</rdfs:label>
    <rdfs:comment>Full model with Loan and Investment entities</rdfs:comment>
  </owl:Ontology>

  <!-- ════════════════  CLASSES  ════════════════ -->

  <owl:Class rdf:about="Customer">
    <rdfs:label>Customer</rdfs:label>
    <rdfs:comment>A bank customer</rdfs:comment>
    <ont:icon>👤</ont:icon>
    <ont:color>#0078D4</ont:color>
  </owl:Class>

  <owl:Class rdf:about="Account">
    <rdfs:label>Account</rdfs:label>
    <rdfs:comment>A financial account</rdfs:comment>
    <ont:icon>🏦</ont:icon>
    <ont:color>#107C10</ont:color>
  </owl:Class>

  <owl:Class rdf:about="Transaction">
    <rdfs:label>Transaction</rdfs:label>
    <rdfs:comment>A financial transaction</rdfs:comment>
    <ont:icon>💳</ont:icon>
    <ont:color>#FFB900</ont:color>
  </owl:Class>

  <owl:Class rdf:about="Loan">
    <rdfs:label>Loan</rdfs:label>
    <rdfs:comment>A loan product</rdfs:comment>
    <ont:icon>📄</ont:icon>
    <ont:color>#D13438</ont:color>
  </owl:Class>

  <owl:Class rdf:about="Investment">
    <rdfs:label>Investment</rdfs:label>
    <rdfs:comment>An investment holding</rdfs:comment>
    <ont:icon>📈</ont:icon>
    <ont:color>#8764B8</ont:color>
  </owl:Class>

  <!-- ════════════════  DATA PROPERTIES – Customer  ════════════════ -->

  <owl:DatatypeProperty rdf:about="customerId">
    <rdfs:label>customerId</rdfs:label>
    <rdfs:domain rdf:resource="Customer"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
    <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="customerName">
    <rdfs:label>name</rdfs:label>
    <rdfs:domain rdf:resource="Customer"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="ssn">
    <rdfs:label>ssn</rdfs:label>
    <rdfs:domain rdf:resource="Customer"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="creditScore">
    <rdfs:label>creditScore</rdfs:label>
    <rdfs:domain rdf:resource="Customer"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <ont:propertyType>integer</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="riskProfile">
    <rdfs:label>riskProfile</rdfs:label>
    <rdfs:domain rdf:resource="Customer"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <!-- ════════════════  DATA PROPERTIES – Account  ════════════════ -->

  <owl:DatatypeProperty rdf:about="accountNumber">
    <rdfs:label>accountNumber</rdfs:label>
    <rdfs:domain rdf:resource="Account"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
    <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="accountType">
    <rdfs:label>type</rdfs:label>
    <rdfs:domain rdf:resource="Account"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="balance">
    <rdfs:label>balance</rdfs:label>
    <rdfs:domain rdf:resource="Account"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <ont:propertyType>decimal</ont:propertyType>
    <ont:unit>USD</ont:unit>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="interestRate">
    <rdfs:label>interestRate</rdfs:label>
    <rdfs:domain rdf:resource="Account"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <ont:propertyType>decimal</ont:propertyType>
    <ont:unit>%</ont:unit>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="openDate">
    <rdfs:label>openDate</rdfs:label>
    <rdfs:domain rdf:resource="Account"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    <ont:propertyType>date</ont:propertyType>
  </owl:DatatypeProperty>

  <!-- ════════════════  DATA PROPERTIES – Transaction  ════════════════ -->

  <owl:DatatypeProperty rdf:about="transactionId">
    <rdfs:label>transactionId</rdfs:label>
    <rdfs:domain rdf:resource="Transaction"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
    <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="transactionAmount">
    <rdfs:label>amount</rdfs:label>
    <rdfs:domain rdf:resource="Transaction"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <ont:propertyType>decimal</ont:propertyType>
    <ont:unit>USD</ont:unit>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="transactionType">
    <rdfs:label>type</rdfs:label>
    <rdfs:domain rdf:resource="Transaction"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="timestamp">
    <rdfs:label>timestamp</rdfs:label>
    <rdfs:domain rdf:resource="Transaction"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    <ont:propertyType>datetime</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="merchant">
    <rdfs:label>merchant</rdfs:label>
    <rdfs:domain rdf:resource="Transaction"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <!-- ════════════════  DATA PROPERTIES – Loan  ════════════════ -->

  <owl:DatatypeProperty rdf:about="loanId">
    <rdfs:label>loanId</rdfs:label>
    <rdfs:domain rdf:resource="Loan"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
    <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="principal">
    <rdfs:label>principal</rdfs:label>
    <rdfs:domain rdf:resource="Loan"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <ont:propertyType>decimal</ont:propertyType>
    <ont:unit>USD</ont:unit>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="apr">
    <rdfs:label>apr</rdfs:label>
    <rdfs:domain rdf:resource="Loan"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <ont:propertyType>decimal</ont:propertyType>
    <ont:unit>%</ont:unit>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="term">
    <rdfs:label>term</rdfs:label>
    <rdfs:domain rdf:resource="Loan"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <ont:propertyType>integer</ont:propertyType>
    <ont:unit>months</ont:unit>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="loanStatus">
    <rdfs:label>status</rdfs:label>
    <rdfs:domain rdf:resource="Loan"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <!-- ════════════════  DATA PROPERTIES – Investment  ════════════════ -->

  <owl:DatatypeProperty rdf:about="holdingId">
    <rdfs:label>holdingId</rdfs:label>
    <rdfs:domain rdf:resource="Investment"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
    <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="symbol">
    <rdfs:label>symbol</rdfs:label>
    <rdfs:domain rdf:resource="Investment"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="shares">
    <rdfs:label>shares</rdfs:label>
    <rdfs:domain rdf:resource="Investment"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <ont:propertyType>decimal</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="purchasePrice">
    <rdfs:label>purchasePrice</rdfs:label>
    <rdfs:domain rdf:resource="Investment"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <ont:propertyType>decimal</ont:propertyType>
    <ont:unit>USD</ont:unit>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="currentValue">
    <rdfs:label>currentValue</rdfs:label>
    <rdfs:domain rdf:resource="Investment"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <ont:propertyType>decimal</ont:propertyType>
    <ont:unit>USD</ont:unit>
  </owl:DatatypeProperty>

  <!-- ════════════════  OBJECT PROPERTIES  ════════════════ -->

  <owl:ObjectProperty rdf:about="customer_owns_acct">
    <rdfs:label>owns</rdfs:label>
    <rdfs:domain rdf:resource="Customer"/>
    <rdfs:range rdf:resource="Account"/>
    <rdfs:comment>Customer's accounts</rdfs:comment>
    <ont:cardinality>one-to-many</ont:cardinality>
    <ont:fromEntityId>Customer</ont:fromEntityId>
    <ont:toEntityId>Account</ont:toEntityId>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="account_has_txn">
    <rdfs:label>has_transaction</rdfs:label>
    <rdfs:domain rdf:resource="Account"/>
    <rdfs:range rdf:resource="Transaction"/>
    <rdfs:comment>Account transactions</rdfs:comment>
    <ont:cardinality>one-to-many</ont:cardinality>
    <ont:fromEntityId>Account</ont:fromEntityId>
    <ont:toEntityId>Transaction</ont:toEntityId>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="customer_has_loan">
    <rdfs:label>has_loan</rdfs:label>
    <rdfs:domain rdf:resource="Customer"/>
    <rdfs:range rdf:resource="Loan"/>
    <rdfs:comment>Customer loans</rdfs:comment>
    <ont:cardinality>one-to-many</ont:cardinality>
    <ont:fromEntityId>Customer</ont:fromEntityId>
    <ont:toEntityId>Loan</ont:toEntityId>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="account_funds_loan">
    <rdfs:label>funds</rdfs:label>
    <rdfs:domain rdf:resource="Account"/>
    <rdfs:range rdf:resource="Loan"/>
    <rdfs:comment>Payment source</rdfs:comment>
    <ont:cardinality>one-to-many</ont:cardinality>
    <ont:fromEntityId>Account</ont:fromEntityId>
    <ont:toEntityId>Loan</ont:toEntityId>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="customer_holds">
    <rdfs:label>holds</rdfs:label>
    <rdfs:domain rdf:resource="Customer"/>
    <rdfs:range rdf:resource="Investment"/>
    <rdfs:comment>Investment portfolio</rdfs:comment>
    <ont:cardinality>one-to-many</ont:cardinality>
    <ont:fromEntityId>Customer</ont:fromEntityId>
    <ont:toEntityId>Investment</ont:toEntityId>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="account_linked">
    <rdfs:label>linked_to</rdfs:label>
    <rdfs:domain rdf:resource="Account"/>
    <rdfs:range rdf:resource="Investment"/>
    <rdfs:comment>Brokerage account link</rdfs:comment>
    <ont:cardinality>one-to-many</ont:cardinality>
    <ont:fromEntityId>Account</ont:fromEntityId>
    <ont:toEntityId>Investment</ont:toEntityId>
  </owl:ObjectProperty>

</rdf:RDF>
